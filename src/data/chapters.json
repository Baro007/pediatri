              },
              {
                "name": "Oskültasyon",
                "description": "Kalp ve akciğer sesleri dinleme",
                "timing": "Çocuk sakinken"
              },
              {
                "name": "Palpasyon",
                "description": "Dokunarak muayene",
                "timing": "Oskültasyon sonrası"
              },
              {
                "name": "Otoskopi/Farenkse bakma",
                "description": "En invaziv muayene adımları",
                "timing": "En son"
              }
            ]
          }
