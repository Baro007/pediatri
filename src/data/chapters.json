        {
          "id": "anamnesis",
          "title": "Pediatrik Anamnez: Sanat ve Bilim",
          "content": {
            "introduction": "Pediatrik anamnez, sadece semptomları listelemek değil, aynı zamanda bir güven ilişkisi kurma ve ailenin endişelerini anlama sürecidir. Bu süreç, hekim, ebeveyn ve çocuk arasındaki karmaşık ve dinamik bir etkileşim olan 'üçlü iletişim' üzerine kuruludur.",
            "keyPoints": [
              "Üçlü iletişim dinamiği (hekim-ebeveyn-çocuk)",
              "Yaş gruplarına göre iletişim stratejileri",
              "Güven kurma teknikleri",
              "HEEADSSS görüşme tekniği (adolesanlar için)"
            ],
            "ageGroups": [
              {
                "age": "0-1 yaş (Bebek)",
                "approach": "Non-verbal iletişim, sakin ses tonu, ani hareketlerden kaçınma, ebeveyn kucağında muayene",
                "tips": "Bebekle doğrudan temas kurmak yerine, önce aileyle konuşarak bebeğin ortama alışmasına izin verin"
              },
              {
                "age": "1-5 yaş (Oyun Çocuğu)",
                "approach": "Egosantrik yaklaşım, oyuna dönüştürme, basit seçenekler sunma",
                "tips": "Muayene aletlerini 'telefon' veya 'ışık' gibi tanıtarak oyuna dönüştürün"
              },
              {
                "age": "6-12 yaş (Okul Çağı)",
                "approach": "Soyut kavramları anlama, mahremiyete saygı, açıklama yapma",
                "tips": "Ne yapılacağını ve neden yapıldığını basitçe açıklayın, sorularına dürüst cevaplar verin"
              },
              {
                "age": "13-18 yaş (Adolesan)",
                "approach": "Birey olarak kabul etme, gizlilik, doğrudan iletişim",
                "tips": "Önce ebeveynle, sonra adolesanla yalnız, daha sonra hep birlikte konuşma stratejisi"
              }
            ]
          }
        },
